# Copy this file to .env and fill in your real values.
# .env is gitignored — safe for secrets like API keys.
# Real environment variables still override values here.

TWINKLE_LLM_BASE_URL=https://api.openai.com/v1
TWINKLE_LLM_API_KEY=
TWINKLE_LLM_MODEL=gpt-4o-mini

# Optional: override the two-process ports (defaults shown)
# TWINKLE_AGENTSERVER_PORT=18000
# TWINKLE_GATEWAY_PORT=19000

# Agent loop step cap (default 1000; supports long agentic runs like Claude Code)
# TWINKLE_AGENT_MAX_STEPS=1000

# --- observability (OTel, agentserver-only; default off = zero-cost no-op) ---
# OTEL_ENABLED=true
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=http://101.37.215.110:4317
# OTEL_SERVICE_NAME=twinkle-agentserver

# --- permissions (Phase 4: tool permission / approval system) ---
# JSON. Default disabled (all ALLOW, command_exec still uses builtin_rules).
# Example to enable: TWINKLE_PERMISSIONS={"enabled":true}
# TWINKLE_PERMISSIONS=
